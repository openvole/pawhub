{
  "name": "@openvole/paw-brain",
  "version": "2.3.0",
  "description": "Unified Brain Paw — multi-provider LLM adapter (Anthropic, OpenAI, Gemini, Ollama, xAI, local Claude Code CLI, mock)",
  "entry": "./dist/index.js",
  "brain": true,
  "category": "brain",
  "inProcess": false,
  "transport": "ipc",
  "tools": [],
  "permissions": {
    "network": ["*"],
    "listen": [],
    "filesystem": [],
    "childProcess": true,
    "env": [
      "BRAIN_PROVIDER",
      "CLAUDE_CODE_CMD",
      "CLAUDE_CODE_CONFIG_DIR",
      "CLAUDE_CODE_ARGS",
      "CLAUDE_CODE_CWD",
      "CLAUDE_CODE_MODEL",
      "CLAUDE_CODE_PERMISSION_MODE",
      "CLAUDE_CODE_TIMEOUT_MS",
      "CLAUDE_CODE_EXPOSE_TOOLS",
      "VOLE_DASHBOARD_URL",
      "VOLE_DASHBOARD_TOKEN",
      "VOLE_SPACE_ID",
      "BRAIN_API_KEY",
      "BRAIN_MODEL",
      "BRAIN_BASE_URL",
      "ANTHROPIC_API_KEY",
      "ANTHROPIC_MODEL",
      "OPENAI_API_KEY",
      "OPENAI_MODEL",
      "GEMINI_API_KEY",
      "GEMINI_MODEL",
      "OLLAMA_HOST",
      "OLLAMA_MODEL",
      "OLLAMA_API_KEY",
      "XAI_API_KEY",
      "XAI_MODEL",
      "BRAIN_FALLBACK",
      "BRAIN_FALLBACK_MODEL",
      "BRAIN_FALLBACK_BASE_URL"
    ]
  }
}
