{
  "name": "@openvole/paw-compact",
  "version": "0.1.0",
  "description": "Default context compactor — summarizes old messages to free context window space",
  "entry": "./dist/index.js",
  "brain": false,
  "category": "infrastructure",
  "inProcess": true,
  "tools": [],
  "permissions": {
    "network": ["*"],
    "listen": [],
    "filesystem": [],
    "env": [
      "VOLE_COMPACT_KEEP_RECENT",
      "VOLE_COMPACT_MODEL",
      "OLLAMA_HOST",
      "OPENAI_API_KEY",
      "GEMINI_API_KEY",
      "ANTHROPIC_API_KEY",
      "XAI_API_KEY"
    ]
  }
}
